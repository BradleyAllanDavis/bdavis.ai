---
// Inline SVG icons, self-hosted (no icon-font/CDN request) -- same reasoning
// as the self-hosted fonts. Brand marks (github/linkedin/x) are the exact
// paths from simple-icons (CC0, no attribution required). sun/moon/
// external-link/download/briefcase/graduation-cap/bolt/storage/device-hub/
// dns/flag/credit-card/terminal are Google's Material Icons (Apache License
// 2.0) -- "wb_sunny", "brightness_2", "open_in_new", "file_download", "work",
// "school", "bolt", "storage", "device_hub", "dns", "flag", "credit_card",
// "terminal" respectively, pulled from Google's own CDN at
// fonts.gstatic.com/s/i/materialicons/<name>/<version>/24px.svg (wb_sunny
// v11, brightness_2 v9, open_in_new/file_download/work/school v1, bolt v10,
// storage v13, device_hub v12, dns v12, flag v18, credit_card v12,
// terminal v1 -- version pinned per-icon by Google, not a shared constant)
// with the decorative fill="none" background rect dropped, since they're
// otherwise single-path (terminal's path has multiple M...z subpaths in one
// d attribute -- window frame, prompt chevron, cursor -- but it's still one
// <path>) and fit this component's one-path-per-icon shape. Fill is
// currentColor so each usage picks up whatever color its containing element
// already has.
export type IconName = 'github' | 'linkedin' | 'x' | 'mail' | 'sun' | 'moon' | 'external-link' | 'download' | 'briefcase' | 'graduation-cap' | 'bolt' | 'storage' | 'device-hub' | 'dns' | 'flag' | 'credit-card' | 'terminal';
interface Props {
  name: IconName;
  size?: number;
  class?: string;
}
const { name, size = 16, class: className } = Astro.props;

