---
// Hidden route. Not linked from nav, noindexed. For Aaron.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Leave a tip?</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      }
      .tip {
        width: min(92vw, 600px);
      }
      h1 {
        margin: 0 0 28px;
        text-align: center;
        font-weight: 600;
        font-size: clamp(24px, 5vw, 34px);
        color: #111;
      }
      button {
        border: 0;
        border-radius: 4px;
        background: #1273eb;
        color: #fff;
        font-family: inherit;
        cursor: pointer;
      }
      .row {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
      }
      .row button {
        flex: 1;
        height: 110px;
        font-size: clamp(22px, 4vw, 30px);
      }
      .custom {
        width: 100%;
        height: 48px;
        font-size: 16px;
      }
    </style>
  </head>
  <body>
    <div class="tip">
      <h1>Leave a tip?</h1>
      <div class="row">
        <button>30%</button>
        <button>34%</button>
        <button>38%</button>
      </div>
      <button class="custom">Custom</button>
    </div>
  </body>
</html>
