---
// Hidden route. Not linked from nav, noindexed. For Aaron.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Leave a tip?</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      }
      .tip {
        width: min(92vw, 600px);
      }
      h1 {
        margin: 0 0 28px;
        text-align: center;
        font-weight: 600;
        font-size: clamp(24px, 5vw, 34px);
        color: #111;
      }
      button {
        border: 0;
        border-radius: 4px;
        background: #1273eb;
        color: #fff;
        font-family: inherit;
        cursor: pointer;
        transition: transform 0.15s ease;
        touch-action: none;
      }
      .row {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
      }
      .row button {
        flex: 1;
        height: 110px;
        font-size: clamp(22px, 4vw, 30px);
      }
      .custom {
        width: 100%;
        height: 48px;
        font-size: 16px;
      }
    </style>
  </head>
  <body>
    <div class="tip">
      <h1>Leave a tip?</h1>
      <div class="row">
        <button data-dodge>30%</button>
        <button data-dodge>34%</button>
        <button id="max">38%</button>
      </div>
      <button class="custom" data-dodge>Custom</button>
    </div>
    <script is:inline>
      const dodge = (el) => (e) => {
        e.preventDefault();
        const dx = (Math.random() - 0.5) * Math.min(window.innerWidth * 0.7, 500);
        const dy = (Math.random() - 0.5) * Math.min(window.innerHeight * 0.6, 400);
        el.style.transform = `translate(${dx}px, ${dy}px)`;
      };
      document.querySelectorAll('[data-dodge]').forEach((el) => {
        const h = dodge(el);
        el.addEventListener('pointerenter', h);
        el.addEventListener('pointerdown', h);
        el.addEventListener('touchstart', h, { passive: false });
        el.addEventListener('click', (e) => e.preventDefault());
      });
      document.getElementById('max').addEventListener('click', () => {
        document.querySelector('.tip').innerHTML = '<h1>Thank you.</h1>';
      });
    </script>
  </body>
</html>
