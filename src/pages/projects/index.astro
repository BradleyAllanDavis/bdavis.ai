---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';

// Sparse, honest list. Link only what is actually public and reachable; most of
// this runs on a private homelab, so those entries describe rather than link.
// `themes` mirrors the same ids in ~/.dotfiles/resume/content.yaml (the
// primary/first theme drives this entry's accent dot -- see global.css's
// theme->accent map) so the two pages agree on what each project "is,"
// even though the prose is written separately for each audience.
const projects = [
  {
    name: 'Nix control plane',
    desc: 'A single declarative Nix repo managing five machines (macOS and NixOS), secrets, networking, home automation, plus AI-agent config and health-check automation.',
    link: null,
    themes: ['infra', 'ai-native', 'devex'],
  },
  {
    name: 'Production MCP servers',
    desc: 'A dozen Model Context Protocol servers running at home, exposing home, finance, and infrastructure systems as tools that agents drive end to end.',
    link: null,
    themes: ['ai-native', 'backend'],
  },
  {
    name: 'Self-hosted homelab',
    desc: 'A Caddy reverse proxy in front of self-hosted git (Forgejo), Pi-hole DNS, and Home Assistant, backed by ZFS-replicated storage with restic backups across a UniFi network, monitored with Prometheus and Grafana.',
    link: null,
    themes: ['infra', 'distributed-systems'],
  },
  {
    name: 'bdavis.ai',
    desc: 'This site. Astro and Markdown, deployed to Cloudflare Pages; the resume page renders from the same content store as the PDF.',
    link: 'https://github.com/BradleyAllanDavis/bdavis.ai',
    themes: ['ai-native', 'infra'],
  },
];
---
<Base title="Projects — Bradley Davis" current="projects" description="Things Bradley Davis has built.">
  <h1>Projects</h1>
  <p class="muted">
    A short list. Most of it runs on a private homelab, so some entries describe
    the work rather than link to it.
  </p>

  {projects.map((p) => (
    <section class="accent-edge" style={`--dot-fill: var(--accent-${p.themes[0]})`}>
      <h3>
        <span class="accent-dot" aria-hidden="true" />
        {p.link
          ? <a href={p.link}>{p.name} <Icon name="external-link" size={14} /></a>
          : p.name}
      </h3>
      <p>{p.desc}</p>
    </section>
  ))}
</Base>
