---
import Base from '../layouts/Base.astro';
import FleetViz from '../components/FleetViz';

// accent: same key Base.astro's nav uses, so a tile's hover border previews
// the color you're about to land on (see global.css [data-accent] rules).
// Bio has none, matching Home/Bio staying unaccented identity pages.
const tiles = [
  { href: '/bio', name: 'Bio', desc: 'Career story, background, and life outside the keyboard.' },
  { href: '/resume', name: 'Resume', desc: 'Experience, projects, and skills. PDF download.', accent: 'resume' },
  { href: '/writing', name: 'Writing', desc: 'Build notes, homelab ops, and other things worth sharing.', accent: 'writing' },
  { href: '/projects', name: 'Projects', desc: 'A Nix control plane, MCP servers in daily use, a self-hosted homelab.', accent: 'projects' },
  { href: '/now', name: 'Now', desc: 'What I am working on at the moment.', accent: 'now' },
];
---
<Base current="home">
  <h1>Backend engineer building agent infrastructure.</h1>
  <p class="lede">
    Seven years on production payment and platform systems. Now running agent
    workflows out of a five-machine Nix homelab.
  </p>
  <FleetViz client:visible />

  <p class="muted">
    Seven years on event-driven payment and platform systems in Java, Spring, and
    Kafka. Now working on MCP servers, multi-agent orchestration, and LLM-app
    architecture. Reach me at <a href="mailto:hire@bdavis.ai">hire@bdavis.ai</a>.
  </p>

  <ul class="tiles">
    {tiles.map((t) => (
      <li>
        <a class="tile" href={t.href} data-accent={t.accent}>
          <span class="tile-name">{t.name}</span>
          <div class="tile-desc">{t.desc}</div>
        </a>
      </li>
    ))}
  </ul>
</Base>
